{
  "name": "@justfortytwo/magrathea",
  "version": "0.0.0",
  "description": "All-in-one installer and lifecycle CLI for justfortytwo — scaffolds the persona surface and provisions the npm engine (guide MCP, safety gate, channel adapters, embedder).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "create-fortytwo": "dist/index.js",
    "fortytwo": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test dist/**/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "justfortytwo",
    "fortytwo",
    "claude-code",
    "personal-assistant",
    "cli",
    "installer"
  ],
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "peerDependencies": {
    "@justfortytwo/guide": "*",
    "@justfortytwo/vogon": "*",
    "@justfortytwo/ford": "*",
    "@justfortytwo/babelfish": "*"
  },
  "peerDependenciesMeta": {
    "@justfortytwo/guide": { "optional": true },
    "@justfortytwo/vogon": { "optional": true },
    "@justfortytwo/ford": { "optional": true },
    "@justfortytwo/babelfish": { "optional": true }
  },
  "fortytwo": {
    "comment": "Compatibility contract this CLI version was authored against. doctor cross-checks the *installed* sibling packages against these ranges; update/rollback record the resolved set into .fortytwo/state.json. TODO(wire): bump these as sibling contracts evolve.",
    "compat": {
      "@justfortytwo/guide": "^0.1.0",
      "@justfortytwo/vogon": "^0.1.0",
      "@justfortytwo/ford": "^0.1.0",
      "@justfortytwo/babelfish": "^0.1.0"
    }
  }
}
